---
import '../styles/globals.css';
---
<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0b1020" />
    <title>Offline — Puente / Bridge</title>
  </head>
  <body>
    <main class="max-w-xl mx-auto px-4 py-12 min-h-screen flex flex-col justify-center">
      <h1 class="text-2xl font-semibold mb-3">You're offline / Está sin conexión</h1>
      <p class="text-[var(--color-muted)] mb-2" lang="en">
        This page hasn't been visited and saved yet. Visit the home, scenarios, and practice pages once with internet so they work offline next time.
      </p>
      <p class="text-[var(--color-muted)]" lang="es">
        Esta página aún no ha sido visitada y guardada. Visite la página principal, los escenarios y la práctica una vez con internet para que funcionen sin conexión la próxima vez.
      </p>
      <div class="mt-6 flex gap-2">
        <a href="/en" class="px-4 py-2 rounded-lg bg-amber-500 text-black font-medium">English</a>
        <a href="/es" class="px-4 py-2 rounded-lg bg-amber-500 text-black font-medium">Español</a>
      </div>
    </main>
  </body>
</html>
