{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_SUBAGENT_MODEL": "sonnet"
  },
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "Bash(npm install)",
      "Bash(npm install:*)",
      "Bash(npm run dev)",
      "Bash(npm run build)",
      "Bash(npm run preview)",
      "Bash(npm run check)",
      "Bash(npm run lint)",
      "Bash(npm run lint:*)",
      "Bash(npm run test)",
      "Bash(npm run test:*)",
      "Bash(npm test)",
      "Bash(npm test:*)",
      "Bash(npx astro:*)",
      "Bash(npx tsc:*)",
      "Bash(git status)",
      "Bash(git diff)",
      "Bash(git diff:*)",
      "Bash(git log)",
      "Bash(git log:*)",
      "Bash(git branch)",
      "Bash(git branch:*)",
      "Bash(git show:*)"
    ],
    "deny": [
      "Bash(git push:*)",
      "Bash(git remote:*)",
      "Bash(npm publish:*)",
      "Bash(npm adduser:*)",
      "Bash(npm login:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "WebFetch(domain:*.google.com)",
      "WebFetch(domain:*.googletagmanager.com)",
      "WebFetch(domain:*.google-analytics.com)",
      "WebFetch(domain:*.facebook.com)",
      "WebFetch(domain:*.meta.com)"
    ]
  }
}
